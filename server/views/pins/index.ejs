<% layout('/layouts/boilerplate') -%>
<body>
    <h1>Welcome to Pinch!!</h1>


    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
        <% for(let pin of allPins) { %>
            <a href="/pins/<%= pin._id %>">
                <div class="card col listing-card">
                    <img src="<%= pin.image.url %>" class="card-img-top" alt="pin_image" style="height: 20rem;">
                    <div class="card-img-overlay"></div>
                    <div class="card-body">
                        <p class="card-text">
                            <b><%= pin.title %></b> <br>
                        </p>
                    </div>
                </div> 
            </a>
            
          <% } %>
    </div>    
</body>